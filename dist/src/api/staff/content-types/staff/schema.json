{
    "kind": "collectionType",
    "collectionName": "staffs",
    "info": {
        "singularName": "staff",
        "pluralName": "staffs",
        "displayName": "Staff"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "phone": {
            "type": "biginteger",
            "required": true,
            "unique": true
        },
        "name": {
            "type": "string"
        },
        "email": {
            "type": "email"
        },
        "password": {
            "type": "password"
        },
        "store": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::store.store",
            "inversedBy": "staff"
        }
    }
}
